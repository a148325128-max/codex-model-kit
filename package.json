{
  "name": "codex-model-kit",
  "version": "0.1.0",
  "description": "Codex multi-provider setup kit for built-in presets, custom OpenAI-compatible APIs, and relay endpoints.",
  "main": "src/codex-models.js",
  "type": "commonjs",
  "scripts": {
    "setup": "node scripts/setup-codex-models.js",
    "setup:dry-run": "node scripts/setup-codex-models.js --dry-run",
